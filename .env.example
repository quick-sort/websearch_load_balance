# API Keys - 复制此文件为 .env 并填入你的 keys
# 注意: .env 文件不应提交到版本控制
#
# 每个 key 是 JSON 数组格式，支持多个 key 做负载均衡
# 本地测试时，集成测试会读取不带 _S 后缀的单值变量名

TAVILY_API_KEYS=["tvly-your-tavily-api-key-here"]
MINIMAXI_API_KEYS=["your-minimax-api-key-here"]
GLM_API_KEYS=["your-zhipu-api-key-here"]
GLM_CODING_API_KEYS=["your-zhipu-coding-api-key-here"]
BOCHA_API_KEYS=["your-bocha-api-key-here"]
FIRECRAWL_API_KEYS=["your-firecrawl-api-key-here"]
ANYCRAWL_API_KEYS=["your-anycrawl-api-key-here"]
SERP_API_KEYS=["your-serpapi-api-key-here"]
SERPER_API_KEYS=["your-serper-api-key-here"]
